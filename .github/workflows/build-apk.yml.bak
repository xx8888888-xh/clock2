name: Build Android APK

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
    - uses: actions/checkout@v4
      with:
        fetch-depth: 1

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'

    - name: Install system dependencies
      run: |
        sudo apt-get update
        sudo apt-get install -y \
          python3-pip build-essential git ffmpeg \
          libsdl2-dev libsdl2-image-dev libsdl2-mixer-dev libsdl2-ttf-dev \
          libportmidi-dev libswscale-dev libavformat-dev libavcodec-dev \
          zlib1g-dev libgstreamer1.0-0 \
          autoconf automake libtool pkg-config libffi-dev libssl-dev liblzma-dev \
          unzip wget || true

    - name: Set up Java 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'

    - name: Install Python dependencies
      run: |
        pip install --upgrade pip setuptools wheel
        pip install cython==0.29.36
        pip install kivy==2.3.0
        pip install pillow
        pip install buildozer==1.4.0

    - name: Setup Android SDK
      run: |
        echo "=== Setup Android SDK ==="
        
        export ANDROID_SDK_ROOT=$HOME/.buildozer/android/platform/android-sdk
        mkdir -p $ANDROID_SDK_ROOT
        
        echo "SDK Root: $ANDROID_SDK_ROOT"
        
        # Create license files
        mkdir -p $ANDROID_SDK_ROOT/licenses
        for lic in android-sdk-license android-sdk-preview-license; do
          echo -e "\n24333f8a63b6825ea9c5514f83c2829b004d1fee" > $ANDROID_SDK_ROOT/licenses/$lic
        done
        
        # Install cmdline-tools
        if [ ! -d "$ANDROID_SDK_ROOT/cmdline-tools/latest/bin" ]; then
          cd /tmp
          wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O cmdline.zip
          unzip -q cmdline.zip
          mkdir -p $ANDROID_SDK_ROOT/cmdline-tools
          mv cmdline-tools $ANDROID_SDK_ROOT/cmdline-tools/latest
        fi
        
        # Accept licenses
        echo -e "y\ny\n" | $ANDROID_SDK_ROOT/cmdline-tools/latest/bin/sdkmanager --licenses --sdk_root=$ANDROID_SDK_ROOT 2>/dev/null || true
        
        # Install SDK components
        echo "=== Installing SDK ==="
        $ANDROID_SDK_ROOT/cmdline-tools/latest/bin/sdkmanager --sdk_root=$ANDROID_SDK_ROOT \
          "platform-tools" \
          "platforms;android-34" \
          "build-tools;34.0.0" || true
        
        # Create symlinks for buildozer
        mkdir -p $ANDROID_SDK_ROOT/tools/bin
        ln -sf $ANDROID_SDK_ROOT/cmdline-tools/latest/bin/sdkmanager $ANDROID_SDK_ROOT/tools/bin/sdkmanager 2>/dev/null || true
        
        echo "=== SDK Ready ==="
        ls -la $ANDROID_SDK_ROOT/

    - name: Pre-download and patch NDK
      run: |
        echo "=== Pre-downloading NDK r25b ==="
        
        export ANDROID_SDK_ROOT=$HOME/.buildozer/android/platform/android-sdk
        NDK_DIR=$HOME/.buildozer/android/platform/android-ndk-r25b
        
        if [ ! -d "$NDK_DIR" ]; then
          cd /tmp
          wget -q https://dl.google.com/android/repository/android-ndk-r25b-linux.zip -O ndk.zip
          unzip -q ndk.zip
          mv android-ndk-r25b $NDK_DIR
          rm ndk.zip
        fi
        
        # Check if NDK r25b has the same issue
        NDK_FLAGS=$NDK_DIR/build/cmake/flags.cmake
        if [ -f "$NDK_FLAGS" ]; then
          echo "Checking NDK r25b flags.cmake..."
          if grep -q "IN_LIST" "$NDK_FLAGS"; then
            echo "NDK r25b also has IN_LIST issue, patching..."
            cp $NDK_FLAGS $NDK_FLAGS.bak
            sed -i 's/if( arg IN_LIST ANDROID_SANITIZE )/# if( arg IN_LIST ANDROID_SANITIZE ) # PATCHED/' $NDK_FLAGS
            echo "Patched NDK r25b"
          else
            echo "NDK r25b doesn't have IN_LIST issue"
          fi
        fi
        
        echo "=== NDK Ready ==="
        ls -la $NDK_DIR/

    - name: Build APK
      env:
        BUILDOZER_WARN_ON_ROOT: '0'
        ANDROID_SDK_ROOT: /home/runner/.buildozer/android/platform/android-sdk
        ANDROID_NDK_ROOT: /home/runner/.buildozer/android/platform/android-ndk-r25b
        ANDROID_NDK_HOME: /home/runner/.buildozer/android/platform/android-ndk-r25b
      run: |
        set -x
        
        export ANDROID_SDK_ROOT=/home/runner/.buildozer/android/platform/android-sdk
        export ANDROID_NDK_ROOT=/home/runner/.buildozer/android/platform/android-ndk-r25b
        export ANDROID_NDK_HOME=/home/runner/.buildozer/android/platform/android-ndk-r25b
        
        cd $GITHUB_WORKSPACE
        echo "Working directory: $(pwd)"
        
        if [ ! -f "buildozer.spec" ]; then
          echo "ERROR: buildozer.spec not found!"
          exit 1
        fi
        
        # Verify NDK
        echo "=== Verify NDK ==="
        ls -la $ANDROID_NDK_ROOT/
        
        # Clean
        rm -rf bin/ .buildozer/
        mkdir -p bin/
        
        echo "=== Build (20-30 min) ==="
        timeout 3000 buildozer android debug 2>&1 || BUILD_EXIT_CODE=$?
        echo "Build exit code: $BUILD_EXIT_CODE"
        
        echo "=== Check results ==="
        if [ -f "bin/"*.apk 2>/dev/null ]; then
          echo "APK found:"
          ls -la bin/*.apk
          APK_SIZE=$(stat -c%s bin/*.apk 2>/dev/null || echo 0)
          APK_SIZE_MB=$((APK_SIZE / 1024 / 1024))
          echo "APK size: $APK_SIZE_MB MB"
        else
          echo "ERROR: No APK found"
          find . -name "*.apk" -type f 2>/dev/null || echo "No APK"
          exit 1
        fi
      timeout-minutes: 60

    - name: Upload APK
      if: success()
      uses: actions/upload-artifact@v4
      with:
        name: clock2-apk
        path: bin/*.apk
